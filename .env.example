# =============================================================================
# Lumina – Environment variables
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# PostgreSQL (Prisma)
# Recommended for most uses
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Stripe (billing)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# App URL (Stripe redirects, OpenRouter callback; fallback: https://lumina.com)
# APP_URL="http://localhost:3000"

# CORS (comma-separated origins; in dev, all origins allowed if unset)
# ALLOWED_ORIGINS="https://app.lumina.com,https://lumina.com"

# Logging
# LOG_LEVEL="debug"
# LOG_FORMAT="pretty"

# Stripe (frontend, if you use Stripe.js)
# STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Clerk webhooks (only if you use Clerk webhook endpoint)
# CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
# or: CLERK_WEBHOOK_SECRET="whsec_..."

# OpenRouter (AI: entries = mood/summary/go deeper; chat = journal chat + weekly tips)
# OPENROUTER_ENTRIES_API_KEY="sk-or-v1-..."
# OPENROUTER_CHAT_API_KEY="sk-or-v1-..."

# Clerk redirects (production; optional)
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/onboard"
